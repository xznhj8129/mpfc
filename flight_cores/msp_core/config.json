{
  "my_name": "uav1",
  "core": {
    "name": "msp_core",
    "cfg": {
      "id": "msp_core",
      "type": "PLATFORM_MULTIROTOR"
    }
  },
  "bus_config": {
    "schema_path": "../../config/bus_topics_schema.json",
    "log_file": "hivebus.log",
    "endpoint": {
      "type": "tcp",
      "host": "127.0.0.1",
      "port": 7777
    }
  },
  "plugins": [
    {
      "plugin": "msp_interface",
      "cfg": {
        "id": "FlightController",
        "is_interface": true,
        "conn_type": "serial",
        "conn_str": "/dev/ttyACM0",
        "conn_bitrate": 115200
      }
    },
    {
      "plugin": "hivelink_interface",
      "cfg": {
        "id": "Hivelink",
        "config_path": "hivelink_config.json",
        "is_datalink": true
      }
    }
  ]
}
