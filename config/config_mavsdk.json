{
  "my_name": "uav1",
  "core": {
      "name": "mavsdk_core",
      "cfg": {
        "id": "mavsdk_core",
        "system_address": "udp://:14550",
        "takeoff_altitude_m": 10.0,
        "post_takeoff_hold_s": 10.0
      }
  },
  "bus_config": {
    "schema_path": "bus_topics_schema.json",
    "log_file": "hivebus.log",
    "endpoint": {
      "type": "tcp",
      "host": "127.0.0.1",
      "port": 7777
    }
  },
  "plugins": [
    {
      "plugin": "mav_interface",
      "cfg": {
        "id": "mav_datalink",
        "is_datalink": true,
        "conn_type": "udp",
        "conn_str": "udpin:0.0.0.0:14551",
        "conn_bitrate": 115200
      }
    }
  ]
}
