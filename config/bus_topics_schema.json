{
  "template": {
    "client": "Bus sender id",
    "op": "pub/sub",
    "topic": "Exact bus topic string (routing key)",
    "time": "Unix epoch milliseconds when the payload is issued",
    "data": "Topic specific payload"
  },
  "topics": {
    "<any_client_id>.GET": {
      "direction": "any <-> any",
      "summary": "General inter-client configuration/parameter get topic",
      "data": {}
    },
    "<any_client_id>.SET": {
      "direction": "any <-> any",
      "summary": "General inter-client configuration/parameter setting topic",
      "data": {
        "<name>": "value key",
        "<value>": "value to set"
      }
    },
    "<interface_id>.MSP.REQUEST": {
      "direction": "any -> msp_interface",
      "summary": "Base prefix for MSP request",
      "data": {
        "data": "MSP payload (JSON)"
      }
    },
    "<interface_id>.MSP.REPLY": {
      "direction": "msp_interface -> any",
      "summary": "Base prefix for MSP replies following request operations",
      "data": {
        "data": "MSP payload (JSON)"
      }
    },
    "<interface_id>.MAVLINK": {
      "direction": "any <-> any",
      "summary": "Base prefix for MAVLink messages",
      "data": {
        "sysid": "mavlink sysid",
        "compid": "mavlink component id",
        "type": "mavlink message type from msg.get_type() ie MAV_GPS_GLOBAL_ORIGIN",
        "data": "JSON parsed payload"
      }
    },
    "<interface_id>.MAVSDK.REQUEST": {
      "direction": "any -> mavsdk_interface",
      "summary": "Requests for MAVSDK actions",
      "data": {
        "request_id": "opaque request id echoed by responses",
        "action": "action identifier (see plugins/mavsdk_interface/actions.py)",
        "params": "action parameters"
      }
    },
    "<interface_id>.MAVSDK.RESPONSE": {
      "direction": "mavsdk_interface -> any",
      "summary": "Responses for MAVSDK actions",
      "data": {
        "request_id": "request id from the matching MAVSDK.REQUEST",
        "action": "action identifier",
        "ok": "boolean status",
        "data": "action-specific payload or error"
      }
    },
    "<interface_id>.MAVSDK.STATE": {
      "direction": "mavsdk_interface -> any",
      "summary": "State snapshot stream from MAVSDK",
      "data": {
        "is_in_air": "bool in-air flag",
        "is_armed": "bool armed flag",
        "is_home_position_ok": "bool home position ready",
        "is_global_position_ok": "bool global position ready",
        "altitude_m": "relative altitude meters",
        "position": "position payload with lat_deg, lon_deg, abs_alt_m, rel_alt_m"
      }
    },
    "<client_id>": {
      "direction": "any <-> any",
      "summary": "Per-client ad hoc topics; the literal topic matches the emitter id prefix",
      "data": "JSON client defined"
    },
    "DIAG.<client_id>": {
      "direction": "broadcast",
      "summary": "Diagnostics and health events, ie startup, crash, shutdown, errors",
      "data": "schema-defined"
    }
  }
}
